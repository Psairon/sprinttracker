# Copy to .env for local runs, or set these as variables in Railway.

# Port the server listens on. Railway injects PORT automatically — do not hardcode it there.
PORT=3000

# Secret used to sign JWT access tokens. MUST be set to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Directory for the persisted SQLite database file.
# On Railway: create a Volume and mount it (e.g. at /data), then set DATA_DIR=/data
# so the database survives redeploys and restarts.
DATA_DIR=/data
